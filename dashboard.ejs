<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Statbot Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { font-family: Arial; background: #1e1e1e; color: #fff; padding: 20px; }
    .card { background: #2d2d2d; padding: 15px; margin: 10px; border-radius: 8px; }
  </style>
</head>
<body>
  <h1>📊 Statbot — Статистика серверов</h1>
  
  <% guilds.forEach(g => { %>
    <div class="card">
      <h2><%= g.name %></h2>
      <p>Участников: <strong><%= g.memberCount %></strong> | Онлайн: <strong><%= g.onlineCount %></strong></p>
      <p>Сообщений: <strong><%= g.totalMessages %></strong></p>
      <p>Войс: <strong><%= g.totalVoiceMinutes %> минут</strong></p>
    </div>
  <% }) %>

  <canvas id="statsChart" width="800" height="400"></canvas>

  <script>
    // Здесь можно добавить реальные графики
    const ctx = document.getElementById('statsChart').getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Пн', 'Вт', 'Ср', 'Чт', 'Пт'],
        datasets: [{
          label: 'Сообщения',
          data: [120, 450, 320, 680, 540],
          borderColor: '#00ff00'
        }]
      }
    });
  </script>
</body>
</html>
