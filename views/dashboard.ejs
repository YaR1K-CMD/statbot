  </script>
  <style>
    .tab-btn {
      background: #222; color: #0f0; border: 1px solid #0f0; 
      padding: 6px 12px; cursor: pointer; border-radius: 4px; font-family: monospace;
    }
    .tab-btn.active { background: #0f0; color: #111; font-weight: bold; }
    .stat-box { background: #111; border: 1px solid #222; padding: 10px; border-radius: 6px; text-align: center; flex: 1; min-width: 60px; }
    .server-icon { width: 50px; height: 50px; border-radius: 50%; border: 1px solid #0f0; object-fit: cover; }
    .avatar-placeholder { width: 50px; height: 50px; border-radius: 50%; border: 1px solid #0f0; background: #222; color: #0f0; display: flex; align-items: center; justify-content: center; font-weight: bold; }
  </style>
</head>
<body style="background:#111; color:#0f0; font-family: 'Courier New', Arial, sans-serif; padding:20px; max-width: 1200px; margin: 0 auto;">
  
  <h1 style="text-align: center; border-bottom: 2px dashed #0f0; padding-bottom: 10px;">Statbot — Аналитика Серверов</h1>
  
  <div id="dashboard-container" style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; margin-top: 20px;">
    <% stats.forEach((s) => { %>
      <div class="server-card" data-guild="<%= s.guildId %>" style="background:#1a1a1a; padding:20px; border: 1px solid #333; border-radius:12px; width: 360px; box-shadow: 0 4px 15px rgba(0,255,0,0.05); position: relative;">
        
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
          <h2 style="color: #fff; margin: 0; text-shadow: 0 0 5px #0f0; max-width: 270px; word-wrap: break-word;"><%= s.name || 'Сервер' %></h2>
          <div>
            <% if (s.iconUrl) { %>
              <img src="<%= s.iconUrl %>" class="server-icon" alt="Icon">
            <% } else { %>
              <div class="avatar-placeholder"><%= (s.name || 'S').substring(0, 2).toUpperCase() %></div>
            <% } %>
          </div>
        </div>
        
        <p style="margin: 5px 0;">Участников: <b class="member-count"><%= s.memberCount %></b> | Онлайн: <b class="online-count" style="color: #00ff00;"><%= s.onlineCount %></b></p>
        
        <div style="display: flex; gap: 8px; margin: 15px 0; font-size: 12px;">
          <div class="stat-box">День<br><b class="cnt-day" style="color:#fff;"><%= s.periods.day %></b></div>
          <div class="stat-box">Неделя<br><b class="cnt-week" style="color:#fff;"><%= s.periods.week %></b></div>
          <div class="stat-box">Месяц<br><b class="cnt-month" style="color:#fff;"><%= s.periods.month %></b></div>
          <div class="stat-box">Всего<br><b class="cnt-all" style="color:#0f0;"><%= s.periods.all %></b></div>
        </div>

        <div style="display: flex; gap: 5px; margin-bottom: 10px; justify-content: center;">
          <button class="tab-btn active" onclick="switchTab('<%= s.guildId %>', 'day')">День</button>
          <button class="tab-btn" onclick="switchTab('<%= s.guildId %>', 'week')">Неделя</button>
          <button class="tab-btn" onclick="switchTab('<%= s.guildId %>', 'month')">Месяц</button>
          <button class="tab-btn" onclick="switchTab('<%= s.guildId %>', 'all')">Всего</button>
        </div>
        
        <div style="display: block; width: 100%; height: 200px; min-height: 200px; margin-top: 5px;">
          <canvas id="chart-<%= s.guildId %>"></canvas>
        </div>
      </div>
    <% }) %>
  </div>

<script>
const charts = {};
const currentTabs = {};
const serverCache = {};

function safeText(el, value) {
  if (!el) return;

  const newValue = String(value ?? '');

  if (el.innerText != newValue) {
    el.innerText = newValue;
  }
}

function normalizeServer(server) {
  return {
    guildId: server.guildId,
    memberCount: server.memberCount ?? 0,
    onlineCount: server.onlineCount ?? 0,
    periods: {
      day: server.periods?.day ?? 0,
      week: server.periods?.week ?? 0,
      month: server.periods?.month ?? 0,
      all: server.periods?.all ?? 0
    },
    charts: {
      week: {
        labels: server.charts?.week?.labels ?? [],
        data: server.charts?.week?.data ?? []
      },
      month: {
        labels: server.charts?.month?.labels ?? [],
        data: server.charts?.month?.data ?? []
      }
    }
  };
}


function getChartConfig(server, tabType) {
  server = normalizeServer(server);

  let labels = [];
  let values = [];
  let type = 'bar';


  switch(tabType) {

    case 'week':
      labels = server.charts.week.labels;
      values = server.charts.week.data;
      type = 'line';
      break;

    case 'month':
      labels = server.charts.month.labels;
      values = server.charts.month.data;
      type = 'line';
      break;

    case 'all':
      labels = ['Все время'];
      values = [server.periods.all];
      type = 'bar';
      break;

    default:
      labels = ['Сегодня'];
      values = [server.periods.day];
      type = 'bar';
  }


  return {
    type,
    data: {
      labels,
      datasets: [
        {
          data: values
        }
      ]
    }
  };
}



function updateChart(chart, config) {

  if (!chart || !config) return;


  chart.config.type = config.type;

  chart.config.data.labels =
    config.data.labels;


  chart.config.data.datasets[0].data =
    config.data.datasets[0].data;


  if (typeof chart.update === 'function') {
    chart.update();
  }
}



async function initDashboard() {

  try {

    const response = await fetch('/api/stats');

    if (!response.ok) return;


    const data = await response.json();


    data.forEach(rawServer => {

      const server = normalizeServer(rawServer);

      serverCache[server.guildId] = server;

      currentTabs[server.guildId] = 'day';


      const canvas =
        document.getElementById(`chart-${server.guildId}`);


      if (!canvas) return;


      const ctx = canvas.getContext('2d');


      charts[server.guildId] =
        new Chart(
          ctx,
          getChartConfig(server,'day')
        );

    });


  } catch(error) {

    console.error(
      'Dashboard init error:',
      error
    );

  }

}




async function switchTab(guildId, tabType) {

  currentTabs[guildId] = tabType;


  const card =
    document.querySelector(
      `.server-card[data-guild="${guildId}"]`
    );


  if (!card) return;



  card
    .querySelectorAll('.tab-btn')
    .forEach(button => {

      const active =
        button.dataset.tab === tabType;


      button.classList.toggle(
        'active',
        active
      );

    });



  const server =
    serverCache[guildId];


  if (!server) return;


  updateChart(
    charts[guildId],
    getChartConfig(
      server,
      tabType
    )
  );

}



async function updateStatsLive(){

  try {


    const response =
      await fetch('/api/stats');


    if (!response.ok) return;


    const data =
      await response.json();



    data.forEach(rawServer=>{


      const server =
        normalizeServer(rawServer);



      serverCache[server.guildId] =
        server;



      const card =
        document.querySelector(
          `.server-card[data-guild="${server.guildId}"]`
        );



      if(!card) return;



      safeText(
        card.querySelector('.member-count'),
        server.memberCount
      );


      safeText(
        card.querySelector('.online-count'),
        server.onlineCount
      );


      safeText(
        card.querySelector('.cnt-day'),
        server.periods.day
      );


      safeText(
        card.querySelector('.cnt-week'),
        server.periods.week
      );


      safeText(
        card.querySelector('.cnt-month'),
        server.periods.month
      );


      safeText(
        card.querySelector('.cnt-all'),
        server.periods.all
      );



      const active =
        currentTabs[server.guildId] || 'day';



      updateChart(
        charts[server.guildId],
        getChartConfig(
          server,
          active
        )
      );


    });


  } catch(error){

    console.error(
      'Live update error:',
      error
    );

  }

}



document.addEventListener(
  'DOMContentLoaded',
  ()=>{

    initDashboard();

    setInterval(
      updateStatsLive,
      5000
    );

  }
);
</script>
