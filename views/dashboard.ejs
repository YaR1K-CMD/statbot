  <style>
    .tab-btn {
      background: #111; color: #0f0; border: 1px solid #222; 
      padding: 6px 14px; cursor: pointer; border-radius: 6px; font-family: monospace;
      transition: all 0.2s ease-in-out;
    }
    .tab-btn:hover { border-color: #0f0; background: #1a1a1a; }
    .tab-btn.active { background: #0f0; color: #111; font-weight: bold; border-color: #0f0; box-shadow: 0 0 10px rgba(0,255,0,0.2); }
    .stat-box { background: #111; border: 1px solid #222; padding: 10px; border-radius: 6px; text-align: center; flex: 1; min-width: 60px; transition: background 0.3s ease; }
    .server-icon { width: 50px; height: 50px; border-radius: 50%; border: 1px solid #0f0; object-fit: cover; box-shadow: 0 0 8px rgba(0,255,0,0.2); }
    .avatar-placeholder { width: 50px; height: 50px; border-radius: 50%; border: 1px solid #0f0; background: #222; color: #0f0; display: flex; align-items: center; justify-content: center; font-weight: bold; }
    .server-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .server-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,255,0,0.08); }
  </style>
</head>
<body style="background:#111; color:#0f0; font-family: 'Courier New', Arial, sans-serif; padding:20px; max-width: 1200px; margin: 0 auto;">
  
  <h1 style="text-align: center; border-bottom: 2px dashed #0f0; padding-bottom: 10px; font-weight: normal; letter-spacing: 1px;">Statbot — Аналитика Серверов</h1>
  
  <div id="dashboard-container" style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; margin-top: 20px;">
    <% stats.forEach((s) => { %>
      <div class="server-card" data-guild="<%= s.guildId %>" style="background:#1a1a1a; padding:20px; border: 1px solid #333; border-radius:12px; width: 360px; position: relative;">
        
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
          <h2 style="color: #fff; margin: 0; text-shadow: 0 0 5px rgba(0,255,0,0.3); max-width: 270px; word-wrap: break-word; font-weight: normal;"><%= s.name || 'Сервер' %></h2>
          <div>
            <% if (s.iconUrl) { %>
              <img src="<%= s.iconUrl %>" class="server-icon" alt="Icon">
            <% } else { %>
              <div class="avatar-placeholder"><%= (s.name || 'S').substring(0, 2).toUpperCase() %></div>
            <% } %>
          </div>
        </div>
        
        <p style="margin: 5px 0; font-size: 14px; color: #ccc;">Участников: <b class="member-count" style="color: #fff;"><%= s.memberCount %></b> | Онлайн: <b class="online-count" style="color: #00ff00;"><%= s.onlineCount %></b></p>
        
        <div style="display: flex; gap: 8px; margin: 15px 0; font-size: 12px;">
          <div class="stat-box">День<br><b class="cnt-day" style="color:#fff; font-size: 14px;"><%= s.periods.day %></b></div>
          <div class="stat-box">Неделя<br><b class="cnt-week" style="color:#fff; font-size: 14px;"><%= s.periods.week %></b></div>
          <div class="stat-box">Месяц<br><b class="cnt-month" style="color:#fff; font-size: 14px;"><%= s.periods.month %></b></div>
          <div class="stat-box">Всего<br><b class="cnt-all" style="color:#0f0; font-size: 14px;"><%= s.periods.all %></b></div>
        </div>

        <div style="display: flex; gap: 5px; margin-bottom: 15px; justify-content: center;">
          <button class="tab-btn active" onclick="switchTab('<%= s.guildId %>', 'day')">День</button>
          <button class="tab-btn" onclick="switchTab('<%= s.guildId %>', 'week')">Неделя</button>
          <button class="tab-btn" onclick="switchTab('<%= s.guildId %>', 'month')">Месяц</button>
          <button class="tab-btn" onclick="switchTab('<%= s.guildId %>', 'all')">Всего</button>
        </div>
        
        <div style="display: block; width: 100%; height: 200px; min-height: 200px; position: relative;">
          <canvas id="chart-<%= s.guildId %>"></canvas>
        </div>
      </div>
    <% }) %>
  </div>

  <script>
    const charts = {};
    const currentTabs = {};

    function getChartConfig(server, tabType) {
      let labels = [];
      let datasetsData = [];
      let chartType = 'bar';

      if (tabType === 'day') {
        labels = ['Сегодня'];
        datasetsData = [server.periods.day];
        chartType = 'bar';
      } else if (tabType === 'week') {
        labels = server.charts.week.labels;
        datasetsData = server.charts.week.data;
        chartType = 'line';
      } else if (tabType === 'month') {
        labels = server.charts.month.labels;
        datasetsData = server.charts.month.data;
        chartType = 'line';
      } else if (tabType === 'all') {
        labels = ['Все время'];
        datasetsData = [server.periods.all];
        chartType = 'bar';
      }

      return {
        type: chartType,
        data: {
          labels: labels,
          datasets: [{ data: datasetsData }]
        }
      };
    }

    async function initDashboard() {
      try {
        const response = await fetch('/api/stats');
        if (!response.ok) return;
        const data = await response.json();

        data.forEach(server => {
          currentTabs[server.guildId] = 'day';
          const el = document.getElementById(`chart-${server.guildId}`);
          if(el) {
            const ctx = el.getContext('2d');
            charts[server.guildId] = new Chart(ctx, getChartConfig(server, 'day'));
          }
        });
      } catch (err) {
        console.error('Ошибка инициализации:', err);
      }
    }

    async function switchTab(guildId, tabType) {
      currentTabs[guildId] = tabType;
      const card = document.querySelector(`.server-card[data-guild="${guildId}"]`);
      if(!card) return;

      card.querySelectorAll('.tab-btn').forEach(btn => {
        if(btn.getAttribute('onclick').includes(`'${tabType}'`)) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      try {
        const res = await fetch('/api/stats');
        const data = await res.json();
        const serverStats = data.find(s => s.guildId === guildId);
        
        if (serverStats) {
          const chart = charts[guildId];
          if(chart) {
            chart.config.type = getChartConfig(serverStats, tabType).type;
            chart.config.data.labels = getChartConfig(serverStats, tabType).data.labels;
            chart.config.data.datasets[0].data = getChartConfig(serverStats, tabType).data.datasets[0].data;
            chart.update();
          }
        }
      } catch (err) {
        console.error(err);
      }
    }

    async function updateStatsLive() {
      try {
        const response = await fetch('/api/stats');
        if (!response.ok) return;
        const data = await response.json();

        data.forEach(serverStats => {
          const card = document.querySelector(`.server-card[data-guild="${serverStats.guildId}"]`);
          if (!card) return;

          if(card.querySelector('.member-count').innerText != serverStats.memberCount)
            card.querySelector('.member-count').innerText = serverStats.memberCount;
            
          if(card.querySelector('.online-count').innerText != serverStats.onlineCount)
            card.querySelector('.online-count').innerText = serverStats.onlineCount;

          card.querySelector('.cnt-day').innerText = serverStats.periods.day;
          card.querySelector('.cnt-week').innerText = serverStats.periods.week;
          card.querySelector('.cnt-month').innerText = serverStats.periods.month;
          card.querySelector('.cnt-all').innerText = serverStats.periods.all;

          const activeTab = currentTabs[serverStats.guildId];
          const chart = charts[serverStats.guildId];

          if (chart) {
            const newConfig = getChartConfig(serverStats, activeTab);
            chart.config.data.labels = newConfig.data.labels;
            // ИСПРАВЛЕНО: Убран индекс, так как структура библиотеки встроена напрямую
            chart.config.data.datasets.data = newConfig.data.datasets.data;
            chart.update();
          }
        });
      } catch (err) {
        console.error(err);
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      initDashboard();
      setInterval(updateStatsLive, 5000);
    });
