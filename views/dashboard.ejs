      init() {
        this.render();
      }
      destroy() {
        delete window.Chart.instances[this.id];
        const container = this.ctx.canvas.parentElement;
        container.innerHTML = `<canvas id="${this.ctx.canvas.id}"></canvas>`;
      }
      update() {
        this.render();
      }
      render() {
        const ctx = this.ctx;
        const w = ctx.canvas.width = ctx.canvas.parentElement.clientWidth;
        const h = ctx.canvas.height = ctx.canvas.parentElement.clientHeight;
        ctx.clearRect(0,0,w,h);
        
        const data = this.config.data.datasets[0].data;
        const labels = this.config.data.labels;
        const max = Math.max(...data, 5);
        
        ctx.strokeStyle = '#222';
        ctx.lineWidth = 1;
        for(let i=0; i<=4; i++) {
          let y = 20 + i * (h - 50) / 4;
          ctx.beginPath(); ctx.moveTo(30, y); ctx.lineTo(w-10, y); ctx.stroke();
          ctx.fillStyle = '#aaa'; ctx.font = '10px monospace';
          ctx.fillText(Math.round(max - (i * max / 4)), 5, y+4);
        }
        
