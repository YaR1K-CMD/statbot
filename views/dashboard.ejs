          ctx.beginPath();
          ctx.strokeStyle = '#00ff00';
          ctx.lineWidth = 2;
          const stepX = (w - 50) / (data.length - 1 || 1);
          data.forEach((val, idx) => {
            const pointY = h - 30 - (val / max) * (h - 50);
