          const barW = (w - 50) / data.length;
          data.forEach((val, idx) => {
            const barH = (val / max) * (h - 50);
            ctx.fillStyle = 'rgba(0, 255, 0, 0.2)';
            ctx.fillRect(40 + idx*barW, h - 30 - barH, barW - 10, barH);
            ctx.strokeStyle = '#00ff00';
            ctx.strokeRect(40 + idx*barW, h - 30 - barH, barW - 10, barH);
            ctx.fillStyle = '#aaa';
